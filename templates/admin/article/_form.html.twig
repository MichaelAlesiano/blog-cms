<div class="admin-form">
{{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        {# Colonna principale #}
        <div class="lg:col-span-2 space-y-6">
            <div class="admin-card p-6 space-y-5">
                <div>
                    {{ form_label(form.title) }}
                    {{ form_widget(form.title) }}
                    {{ form_errors(form.title, {'attr': {'class': 'form-error'}}) }}
                </div>

                <div>
                    {{ form_label(form.excerpt) }}
                    {{ form_widget(form.excerpt, {'attr': {'rows': 3}}) }}
                    {{ form_errors(form.excerpt, {'attr': {'class': 'form-error'}}) }}
                </div>

                <div>
                    {{ form_label(form.content) }}
                    {{ form_widget(form.content, {'attr': {'rows': 14}}) }}
                    {{ form_errors(form.content, {'attr': {'class': 'form-error'}}) }}
                </div>
            </div>
        </div>

        {# Sidebar destra #}
        <div class="space-y-6">
            <div class="admin-card p-6 space-y-5">
                <div>
                    {{ form_label(form.category) }}
                    {{ form_widget(form.category) }}
                    {{ form_errors(form.category, {'attr': {'class': 'form-error'}}) }}
                </div>

                <div>
                    {{ form_label(form.coverImageFile) }}
                    {{ form_widget(form.coverImageFile) }}
                    {{ form_errors(form.coverImageFile, {'attr': {'class': 'form-error'}}) }}
                </div>

                <div>
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Tag</p>
                    <div class="flex flex-wrap gap-2">
                        {% for child in form.tags %}
                            <label class="inline-flex items-center gap-2 px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-lg hover:border-indigo-500 transition cursor-pointer text-sm text-gray-700">
                                {{ form_widget(child) }}
                                {{ child.vars.label }}
                            </label>
                        {% endfor %}
                    </div>
                </div>

                <div class="flex items-center gap-3 pt-2 border-t border-gray-200">
                    {{ form_widget(form.published) }}
                    {{ form_label(form.published, null, {'label_attr': {'class': 'text-sm font-medium text-gray-700 cursor-pointer'}}) }}
                </div>
            </div>

            <div class="space-y-2">
                <button type="submit" class="btn btn-primary w-full justify-center">
                    Salva articolo
                </button>

                {% if article is defined and article.id %}
                    <a href="{{ path('admin_article_preview', {id: article.id}) }}"
                        target="_blank"
                        class="btn btn-ghost w-full justify-center border border-gray-300 hover:border-indigo-500">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                        </svg>
                        Anteprima
                    </a>
                {% endif %}
            </div>
        </div>
    </div>

{{ form_end(form) }}
</div>
