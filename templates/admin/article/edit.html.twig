{% extends 'admin/layout.html.twig' %}

{% block title %}Modifica: {{ article.title }} — Blog CMS{% endblock %}

{% block body %}
    <div class="mb-6">
        <a href="{{ path('admin_article_index') }}" class="text-sm text-gray-500 hover:text-indigo-600 transition">← Torna alla lista</a>
    </div>
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Modifica articolo</h1>

    {% if article.coverImage %}
        <div class="mb-6">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Immagine attuale</p>
            <img src="{{ asset('uploads/covers/' ~ article.coverImage) }}" alt="{{ article.title }}"
                class="max-w-xs rounded-lg border border-gray-300">
        </div>
    {% endif %}

    {{ include('admin/article/_form.html.twig') }}
{% endblock %}
