<div class="admin-form">
{{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}

    <div class="admin-card p-6 space-y-5 max-w-xl">
        <div>
            {{ form_label(form.fullName) }}
            {{ form_widget(form.fullName) }}
            {{ form_errors(form.fullName, {'attr': {'class': 'form-error'}}) }}
        </div>

        <div>
            {{ form_label(form.email) }}
            {{ form_widget(form.email) }}
            {{ form_errors(form.email, {'attr': {'class': 'form-error'}}) }}
        </div>

        <div>
            {{ form_label(form.plainPassword) }}
            {{ form_widget(form.plainPassword) }}
            {{ form_errors(form.plainPassword, {'attr': {'class': 'form-error'}}) }}
        </div>

        <div>
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Ruolo</p>
            <div class="flex gap-4">
                {% for child in form.roles %}
                    <label class="inline-flex items-center gap-2 px-3 py-1.5 bg-gray-100 border border-gray-300 rounded-lg hover:border-indigo-500 transition cursor-pointer text-sm text-gray-700">
                        {{ form_widget(child) }}
                        {{ child.vars.label }}
                    </label>
                {% endfor %}
            </div>
            {{ form_errors(form.roles, {'attr': {'class': 'form-error'}}) }}
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Salva utente</button>

{{ form_end(form) }}
</div>
