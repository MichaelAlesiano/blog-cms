{% extends 'admin/layout.html.twig' %}

{% block title %}Dashboard — Blog CMS{% endblock %}

{% block body %}
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
        <a href="{{ path('admin_article_new') }}" class="btn btn-primary">+ Nuovo articolo</a>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
        <div class="stat-card" style="border-left-color: #334155;">
            <div class="stat-label">Articoli</div>
            <div class="stat-value text-gray-900">{{ totalArticles }}</div>
        </div>
        <div class="stat-card" style="border-left-color: #059669;">
            <div class="stat-label">Pubblicati</div>
            <div class="stat-value text-emerald-600">{{ publishedArticles }}</div>
        </div>
        <div class="stat-card" style="border-left-color: #d97706;">
            <div class="stat-label">Bozze</div>
            <div class="stat-value text-amber-600">{{ draftArticles }}</div>
        </div>
        <div class="stat-card" style="border-left-color: #6366f1;">
            <div class="stat-label">Categorie</div>
            <div class="stat-value text-indigo-600">{{ totalCategories }}</div>
        </div>
    </div>

    <div class="grid grid-cols-3 gap-4 mb-8">
        <div class="stat-card" style="border-left-color: #0891b2;">
            <div class="stat-label">Visualizzazioni totali</div>
            <div class="stat-value text-cyan-600">{{ totalViews }}</div>
        </div>
        <div class="stat-card" style="border-left-color: #db2777;">
            <div class="stat-label">Like totali</div>
            <div class="stat-value text-pink-600">{{ totalLikes }}</div>
        </div>
        <div class="stat-card" style="border-left-color: #7c3aed;">
            <div class="stat-label">Commenti totali</div>
            <div class="stat-value text-violet-600">{{ totalComments }}</div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="admin-card">
            <div class="admin-card-header flex items-center justify-between">
                <span>Ultimi articoli</span>
                <a href="{{ path('admin_article_index') }}" class="text-xs text-indigo-600 hover:text-indigo-500">Vedi tutti →</a>
            </div>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Titolo</th>
                        <th class="text-center">👁</th>
                        <th class="text-center">👍</th>
                        <th>Stato</th>
                    </tr>
                </thead>
                <tbody>
                    {% for article in latestArticles %}
                        <tr>
                            <td class="font-medium">
                                <a href="{{ path('admin_article_edit', {id: article.id}) }}" class="hover:text-indigo-600 transition">
                                    {{ article.title|length > 35 ? article.title[:35] ~ '...' : article.title }}
                                </a>
                            </td>
                            <td class="text-center text-gray-400 text-sm">{{ article.views }}</td>
                            <td class="text-center text-gray-400 text-sm">{{ article.likes }}</td>
                            <td>
                                {% if article.published %}
                                    <span class="badge badge-success">Pub</span>
                                {% else %}
                                    <span class="badge badge-warning">Bozza</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-6 text-gray-400">Nessun articolo.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <div class="admin-card">
            <div class="admin-card-header flex items-center justify-between">
                <span>Ultimi commenti</span>
                <a href="{{ path('admin_comment_index') }}" class="text-xs text-indigo-600 hover:text-indigo-500">Vedi tutti →</a>
            </div>
            <div class="divide-y divide-gray-100">
                {% for comment in latestComments %}
                    <div class="px-6 py-4">
                        <div class="flex items-start justify-between gap-4">
                            <div class="min-w-0">
                                <p class="text-sm font-medium text-gray-800">{{ comment.authorName }}</p>
                                <p class="text-sm text-gray-500 mt-0.5 truncate">{{ comment.content|length > 80 ? comment.content[:80] ~ '...' : comment.content }}</p>
                                <p class="text-xs text-gray-400 mt-1">
                                    su <span class="text-gray-600">{{ comment.article.title|length > 30 ? comment.article.title[:30] ~ '...' : comment.article.title }}</span>
                                    · {{ comment.createdAt|date('d/m/Y H:i') }}
                                </p>
                            </div>
                            <form action="{{ path('admin_comment_delete', {id: comment.id}) }}" method="post"
                                onsubmit="return confirm('Eliminare questo commento?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ comment.id) }}">
                                <button type="submit" class="btn-danger text-xs shrink-0">✕</button>
                            </form>
                        </div>
                    </div>
                {% else %}
                    <div class="px-6 py-8 text-center text-gray-400">Nessun commento.</div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}
