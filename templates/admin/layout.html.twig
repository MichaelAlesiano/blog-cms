<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin — Blog CMS{% endblock %}</title>
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
</head>
<body class="bg-gray-950 text-gray-200">

    <aside class="admin-sidebar">
        <div class="sidebar-logo">
            <a href="{{ path('admin_dashboard') }}" class="text-indigo-400 hover:text-indigo-300 transition no-underline">
                Blog CMS
            </a>
        </div>

        <nav class="sidebar-nav">
            <a href="{{ path('admin_dashboard') }}"
                class="sidebar-link {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}">
                <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                Dashboard
            </a>
            <a href="{{ path('admin_article_index') }}"
                class="sidebar-link {% if 'admin_article' in app.request.attributes.get('_route') %}active{% endif %}">
                <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Articoli
            </a>
            <a href="{{ path('admin_category_index') }}"
                class="sidebar-link {% if 'admin_category' in app.request.attributes.get('_route') %}active{% endif %}">
                <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                Categorie
            </a>
            <a href="{{ path('admin_tag_index') }}"
                class="sidebar-link {% if 'admin_tag' in app.request.attributes.get('_route') %}active{% endif %}">
                <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/></svg>
                Tag
            </a>
            <a href="{{ path('admin_comment_index') }}"
                class="sidebar-link {% if 'admin_comment' in app.request.attributes.get('_route') %}active{% endif %}">
                <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/></svg>
                Commenti
            </a>
            <a href="{{ path('admin_user_index') }}"
                class="sidebar-link {% if 'admin_user' in app.request.attributes.get('_route') %}active{% endif %}">
                <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                Utenti
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="text-xs text-gray-500 mb-2">{{ app.user.fullName }}</div>
            <div class="flex items-center gap-3">
                <a href="{{ path('blog_index') }}" class="text-xs text-gray-500 hover:text-indigo-400 transition">Vai al sito</a>
                <a href="{{ path('app_logout') }}" class="text-xs text-gray-500 hover:text-red-400 transition">Esci</a>
            </div>
        </div>
    </aside>

    <div class="admin-content">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="px-8 pt-6">
                    <div class="p-4 rounded-lg text-sm
                        {% if type == 'success' %}bg-emerald-50 text-emerald-700 border border-emerald-200
                        {% elseif type == 'error' %}bg-red-50 text-red-700 border border-red-200
                        {% else %}bg-indigo-50 text-indigo-700 border border-indigo-200{% endif %}">
                        {{ message }}
                    </div>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="p-8">
            {% block body %}{% endblock %}
        </div>
    </div>

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</body>
</html>
