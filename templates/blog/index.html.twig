{% extends 'base.html.twig' %}

{% block title %}
    {% if currentCategory %}{{ currentCategory.name }} — {% endif %}Blog — Blog CMS
{% endblock %}

{% block body %}
<div class="max-w-6xl mx-auto px-4 py-8">

    <div class="flex flex-col md:flex-row gap-8">

        <div class="flex-1">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">
                {% if currentCategory %}
                    {{ currentCategory.name }}
                {% else %}
                    Articoli
                {% endif %}
            </h1>
            {% if currentCategory and currentCategory.description %}
                <p class="text-gray-500 mb-6">{{ currentCategory.description }}</p>
            {% else %}
                <p class="text-gray-500 mb-6">Ultimi articoli pubblicati</p>
            {% endif %}

            {% if pagination|length > 0 %}
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    {% for article in pagination %}
                        <article class="bg-white rounded-xl shadow-md shadow-indigo-500/5 border border-indigo-100/60 overflow-hidden hover:shadow-lg hover:shadow-indigo-500/10 hover:border-indigo-200 transition group">
                            {% if article.coverImage %}
                                <a href="{{ path('blog_show', {slug: article.slug}) }}">
                                    <img src="{{ asset('uploads/covers/' ~ article.coverImage) }}" alt="{{ article.title }}"
                                        class="w-full h-48 object-cover group-hover:opacity-90 transition">
                                </a>
                            {% else %}
                                <a href="{{ path('blog_show', {slug: article.slug}) }}">
                                    <div class="w-full h-48 bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center">
                                        <span class="text-white/30 text-5xl">✦</span>
                                    </div>
                                </a>
                            {% endif %}

                            <div class="p-5">
                                <div class="flex items-center gap-2 mb-2">
                                    {% if article.category %}
                                        <a href="{{ path('blog_index', {category: article.category.slug}) }}"
                                            class="text-xs font-semibold text-indigo-600 bg-indigo-50 px-2.5 py-0.5 rounded-full hover:bg-indigo-100 transition">
                                            {{ article.category.name }}
                                        </a>
                                    {% endif %}
                                    <span class="text-xs text-gray-400">{{ article.createdAt|date('d/m/Y') }}</span>
                                </div>

                                <h2 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-indigo-600 transition">
                                    <a href="{{ path('blog_show', {slug: article.slug}) }}">
                                        {{ article.title }}
                                    </a>
                                </h2>

                                {% if article.excerpt %}
                                    <p class="text-sm text-gray-500 line-clamp-3">{{ article.excerpt }}</p>
                                {% endif %}

                                <div class="mt-4 flex items-center justify-between pt-3 border-t border-gray-100">
                                    <a href="{{ path('blog_show', {slug: article.slug}) }}"
                                        class="text-sm font-semibold text-indigo-600 hover:text-indigo-500 transition">
                                        Leggi tutto →
                                    </a>
                                    <div class="flex items-center gap-3 text-xs text-gray-400">
                                        <span>👁 {{ article.views }}</span>
                                        <span>👍 {{ article.likes }}</span>
                                        <span>💬 {{ article.comments|length }}</span>
                                    </div>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>

                {% if pagination.getTotalItemCount > 6 %}
                    <div class="mt-8 flex justify-center">
                        <nav class="flex items-center gap-1">
                            {% if pagination.getCurrentPageNumber > 1 %}
                                <a href="{{ path('blog_index', {page: pagination.getCurrentPageNumber - 1, category: currentCategory ? currentCategory.slug : null}) }}"
                                    class="px-3 py-2 text-sm text-gray-500 bg-white border border-gray-200 rounded-lg hover:border-indigo-300 hover:text-indigo-600 transition shadow-sm">
                                    ← Precedente
                                </a>
                            {% endif %}

                            {% set totalPages = (pagination.getTotalItemCount / 6)|round(0, 'ceil') %}
                            {% for i in 1..totalPages %}
                                {% if i == pagination.getCurrentPageNumber %}
                                    <span class="px-3 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg shadow-sm">{{ i }}</span>
                                {% else %}
                                    <a href="{{ path('blog_index', {page: i, category: currentCategory ? currentCategory.slug : null}) }}"
                                        class="px-3 py-2 text-sm text-gray-500 bg-white border border-gray-200 rounded-lg hover:border-indigo-300 hover:text-indigo-600 transition shadow-sm">
                                        {{ i }}
                                    </a>
                                {% endif %}
                            {% endfor %}

                            {% if pagination.getCurrentPageNumber < totalPages %}
                                <a href="{{ path('blog_index', {page: pagination.getCurrentPageNumber + 1, category: currentCategory ? currentCategory.slug : null}) }}"
                                    class="px-3 py-2 text-sm text-gray-500 bg-white border border-gray-200 rounded-lg hover:border-indigo-300 hover:text-indigo-600 transition shadow-sm">
                                    Successivo →
                                </a>
                            {% endif %}
                        </nav>
                    </div>
                {% endif %}

            {% else %}
                <div class="bg-white rounded-xl shadow-md border border-indigo-100/60 p-8 text-center">
                    <p class="text-gray-400">Nessun articolo trovato.</p>
                    {% if currentCategory %}
                        <a href="{{ path('blog_index') }}" class="text-sm text-indigo-600 hover:underline mt-2 inline-block">
                            Vedi tutti gli articoli
                        </a>
                    {% endif %}
                </div>
            {% endif %}
        </div>

        <aside class="w-full md:w-64 shrink-0">
            <div class="bg-slate-900 rounded-xl p-5 sticky top-24">
                <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Categorie</h3>
                <ul class="space-y-1">
                    <li>
                        <a href="{{ path('blog_index') }}"
                            class="block text-sm px-3 py-1.5 rounded-lg transition
                                {% if not currentCategory %}bg-indigo-600 text-white font-medium{% else %}text-slate-400 hover:bg-slate-800{% endif %}">
                            Tutte
                        </a>
                    </li>
                    {% for category in categories %}
                        <li>
                            <a href="{{ path('blog_index', {category: category.slug}) }}"
                                class="block text-sm px-3 py-1.5 rounded-lg transition
                                    {% if currentCategory and currentCategory.id == category.id %}bg-indigo-600 text-white font-medium{% else %}text-slate-400 hover:bg-slate-800{% endif %}">
                                {{ category.name }}
                                <span class="{% if currentCategory and currentCategory.id == category.id %}text-white/70{% else %}text-slate-600{% endif %}">({{ category.articles|length }})</span>
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </div>
        </aside>

    </div>

</div>
{% endblock %}
